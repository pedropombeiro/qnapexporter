#!/usr/bin/env bash
#MISE description="Run formatters and auto-fixable linters"
#USAGE arg "[files]" var help="Specific files to fix (default: all files)"

set -euo pipefail

echo "Running hk hooks..."
# shellcheck disable=SC2154
eval "files=(${usage_files:-})"
# shellcheck disable=SC2154
if [ ${#files[@]} -gt 0 ]; then
  hk fix "${files[@]}"
else
  hk fix --all
fi
